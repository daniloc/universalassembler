{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "#ua/*": ["./system/library/*"]
    }
  },
  "include": [
    "Specification.ts",
    "system/**/*.ts"
  ]
}
